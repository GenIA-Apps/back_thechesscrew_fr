# Server Configuration
PORT=3000

# IP Whitelist Authorization
# AUTHORIZED_IP controls which IP addresses can access the API
# 
# Single IP:
# AUTHORIZED_IP=127.0.0.1
#
# Multiple IPs (comma-separated):
# AUTHORIZED_IP=192.168.1.1,10.0.0.1,127.0.0.1
#
# Leave empty or comment out to disable IP check (development mode)
# AUTHORIZED_IP=
